# House Price Prediction System - Environment Configuration

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Model Configuration
MODEL_PATH=./model/best_model.joblib
PREPROCESSOR_PATH=./model/preprocessor.joblib
METRICS_PATH=./model/metrics.json

# Data Configuration
DATA_PATH=./data/raw/train.csv
PROCESSED_DATA_PATH=./data/processed/

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Training Configuration
RANDOM_STATE=42
TEST_SIZE=0.2
CV_FOLDS=5
N_JOBS=-1

# Feature Engineering
CURRENT_YEAR=2024

# Development
DEBUG=false
